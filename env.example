# Backend API Configuration
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_WEBSOCKET_URL=ws://localhost:8000

# Keycloak Frontend Configuration
NEXTAUTH_URL=http://localhost:3000
# Better Auth uses NEXTAUTH_URL as fallback, or set NEXT_PUBLIC_BETTER_AUTH_URL
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Better Auth Secret (for cookie encryption) - generate with: openssl rand -base64 32
# If not set, Better Auth will generate one automatically (not recommended for production)
BETTER_AUTH_SECRET=your-better-auth-secret-here

KEYCLOAK_CLIENT_ID=marketing-tool-frontend
KEYCLOAK_CLIENT_SECRET=your-frontend-client-secret
KEYCLOAK_ISSUER=https://your-keycloak-server.com/realms/your-realm-name

# IMPORTANT: In Keycloak, configure the following Valid Redirect URI:
# For development: http://localhost:3000/api/auth/oauth2/callback/keycloak
# For production: https://your-domain.com/api/auth/oauth2/callback/keycloak
# 
# Steps to configure in Keycloak:
# 1. Go to your Keycloak Admin Console
# 2. Select your realm
# 3. Go to Clients > Select your client (marketing-tool-frontend)
# 4. In "Valid Redirect URIs", add the callback URL above
# 5. Save the configuration
